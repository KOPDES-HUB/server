generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- AUTHENTICATION & AUTHORIZATION MODELS ---
model AuthGroup {
  id         String    @id @default(uuid())
  name       String    @db.VarChar(100)
  definition String?   @db.Text
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  createdBy  String?   @map("created_by")
  updatedBy  String?   @map("updated_by")

  authPermToGroup AuthPermToGroup[]
  authUserToGroup AuthUserToGroup[]

  @@map("auth_groups")
}

model AuthLoginAttempt {
  id            String    @id @default(uuid())
  ipAddress     String    @map("ip_address") @db.VarChar(39)
  timestamp     DateTime? @default(now())
  loginAttempts Int?      @default(0) @map("login_attempts") @db.SmallInt

  @@map("auth_login_attempts")
}

model AuthPerm {
  id         String    @id @default(uuid())
  name       String    @db.VarChar(100)
  definition String?   @db.VarChar(200)
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  createdBy  String?   @map("created_by")
  updatedBy  String?   @map("updated_by")

  authPermToGroup AuthPermToGroup[]
  menus           Menu[]

  @@map("auth_perms")
}

model AuthUserToGroup {
  userId  String @map("user_id")
  groupId String @map("group_id")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  group AuthGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("auth_user_to_group")
}

enum StatusRegistrasiAkun {
  DIAJUKAN
  DISETUJUI
  DITOLAK
  DITANGGUHKAN
}

model AuthUser {
  id               String    @id @default(uuid())
  email            String    @unique @db.VarChar(100)
  nik              String?   @unique @db.VarChar(16)
  password         String?   @db.VarChar(255)
  username         String    @db.VarChar(100)

  isAdmin          Boolean   @default(false) @map("is_admin")

  statusRegistrasi StatusRegistrasiAkun @default(DIAJUKAN) @map("status_registrasi")
  alasanPenolakan  String?              @map("alasan_penolakan") @db.Text

  // Data pendaftaran — disimpan saat DIAJUKAN, disalin ke anggota saat DISETUJUI
  koperasiRef   String? @map("koperasi_ref")
  alamatLengkap String? @map("alamat_lengkap") @db.Text
  fileKtp       String? @map("file_ktp") @db.Text
  fileSelfieKtp String? @map("file_selfie_ktp") @db.Text

  noWA String? @map("no_wa") @db.VarChar(20)

  // Relasi 1:1 — record anggota hanya ada setelah DISETUJUI
  anggota kopdes_hub_sch_anggota_koperasi?

  banned           Boolean   @default(false)
  lastLogin        DateTime? @map("last_login")
  lastActivity     DateTime? @map("last_activity")
  forgotExp        String?   @map("forgot_exp") @db.Text
  rememberTime     DateTime? @map("remember_time")
  rememberExp      String?   @map("remember_exp") @db.Text
  verificationCode String?   @map("verification_code") @db.Text
  totpSecret       String?   @map("totp_secret") @db.VarChar(16)
  ipAddress        String?   @map("ip_address") @db.Text

  avatar String? @db.Text

  telegramChatId   String?   @map("telegram_chat_id") @db.VarChar(100)
  telegramUsername String?   @map("telegram_username") @db.VarChar(100)
  notifyEmail      Boolean   @default(true) @map("notify_email")
  notifyTelegram   Boolean   @default(false) @map("notify_telegram")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  authUserTokens  AuthUserToken[]
  authUserToGroup AuthUserToGroup[]

  assignmentsGiven     Assignment[]    @relation("AssignmentGiver")
  assignmentsReceived  Assignment[]    @relation("AssignmentReceiver")
  assignmentLogs       AssignmentLog[]
  activities           Activity[]      @relation("ActivityUser")
  activitiesGiven      Activity[]      @relation("ActivityGiver")
  notifications        Notification[]
  leaveRequests        LeaveRequest[]  @relation("LeaveRequestUser")
  leaveRequestsManaged LeaveRequest[]  @relation("LeaveRequestManager")
  leaveRequestsFinance LeaveRequest[]  @relation("LeaveRequestFinance")
  applicationTeams     ApplicationInfoTeam[]
  projectsOwned        Project[]       @relation("ProjectOwner")

  @@map("auth_users")
}

model AuthPermToGroup {
  permId    String @map("perm_id")
  groupId   String @map("group_id")
  canCreate Int?   @default(0) @map("can_create") @db.SmallInt
  canRead   Int?   @default(0) @map("can_read") @db.SmallInt
  canUpdate Int?   @default(0) @map("can_update") @db.SmallInt
  canDelete Int?   @default(0) @map("can_delete") @db.SmallInt

  createdBy String?   @map("created_by")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedBy String?   @map("updated_by")
  updatedAt DateTime? @updatedAt @map("updated_at")

  group      AuthGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission AuthPerm  @relation(fields: [permId], references: [id], onDelete: Cascade)

  @@id([permId, groupId])
  @@index([groupId])
  @@map("auth_perm_to_group")
}

model Menu {
  id       String @id @default(uuid())
  name     String @db.VarChar(50)
  url      String @db.VarChar(250)
  icon     String @db.VarChar(100)
  sequence Int

  parentId String? @map("parent_id")
  parent   Menu?   @relation("MenuToMenu", fields: [parentId], references: [id])
  children Menu[]  @relation("MenuToMenu")

  module String @db.VarChar(20)
  type   String @db.VarChar(20)

  permId     String   @map("perm_id")
  permission AuthPerm @relation(fields: [permId], references: [id], onDelete: Cascade)

  createdAt DateTime? @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([permId])
  @@map("menus")
}

model AuthUserToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  refreshToken String    @map("refresh_token") @db.Text
  deviceInfo   String?   @map("device_info") @db.Text
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime? @default(now()) @map("created_at")

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_user_tokens")
}

// --- OTHER MODELS ---

model SystemAuditLog {
  id        String  @id @default(uuid())
  action    String
  actorId   String  @map("actor_id")
  details   Json?
  ipAddress String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_audit_log")
}

// --- MASTER PROYEK ---
model Project {
  id             String          @id @default(uuid())
  code           String          @unique @db.VarChar(20) // BIT-001
  name           String          @db.VarChar(200)
  description    String?         @db.Text
  status         ProjectStatus   @default(ACTIVE)
  contractStatus ContractStatus  @default(POTENTIAL) @map("contract_status")
  category       ProjectCategory @default(PROJECT)
  year           Int?
  contractValue  Float?          @map("contract_value")
  contractStart  DateTime?       @map("contract_start")
  contractEnd    DateTime?       @map("contract_end")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") // FK ke AuthUser.id (loose)
  updatedBy String?   @map("updated_by")

  ownerId   String?   @map("owner_id")
  owner     AuthUser? @relation("ProjectOwner", fields: [ownerId], references: [id])

  assignments Assignment[]
  activities  Activity[]

  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum ContractStatus {
  POTENTIAL
  NOT_CONTRACTED
  CONTRACTED
}

enum ProjectCategory {
  PROJECT
  PRODUCT
  OTHERS
}

// --- PENUGASAN ---
model Assignment {
  id           String @id @default(uuid())
  projectId    String @map("project_id")
  assignedById String @map("assigned_by_id")
  assignedToId String @map("assigned_to_id")

  title         String   @db.VarChar(200)
  description   String?  @db.Text
  startDatetime DateTime @map("start_datetime")
  endDatetime   DateTime @map("end_datetime") // deadline

  status      AssignmentStatus @default(PENDING)
  completedAt DateTime?        @map("completed_at") // kapan di-mark selesai
  deadlineEmailSent Boolean @default(false) @map("deadline_email_sent")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  project    Project  @relation(fields: [projectId], references: [id])
  assignedBy AuthUser @relation("AssignmentGiver", fields: [assignedById], references: [id])
  assignedTo AuthUser @relation("AssignmentReceiver", fields: [assignedToId], references: [id])

  logs AssignmentLog[]

  @@index([projectId])
  @@index([assignedToId])
  @@index([assignedById])
  @@map("assignments")
}

enum AssignmentStatus {
  PENDING // Belum dilaksanakan
  PENDING_STATUS // Pending / Ditunda
  IN_PROGRESS // Sedang dilaksanakan
  COMPLETED // Selesai
  COMPLETED_LATE // Selesai terlambat
  LATE_WITH_REASON // Terlambat dengan alasan
}

// --- LOG / AUDIT TRAIL ---
model AssignmentLog {
  id           String @id @default(uuid())
  assignmentId String @map("assignment_id")
  changedById  String @map("changed_by_id")

  oldStatus AssignmentStatus? @map("old_status")
  newStatus AssignmentStatus  @map("new_status")
  note      String?           @db.Text

  changedAt DateTime @default(now()) @map("changed_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  changedBy  AuthUser   @relation(fields: [changedById], references: [id])

  @@index([assignmentId])
  @@map("assignment_logs")
}

// --- NOTIFIKASI ---
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String   @db.VarChar(100)
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  link      String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// --- AKTIVITAS ---
model Activity {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  projectId    String? @map("project_id")
  assignedById String? @map("assigned_by_id")

  title         String   @db.VarChar(200)
  description   String?  @db.Text
  startDatetime DateTime @map("start_datetime")
  endDatetime   DateTime @map("end_datetime")

  status      ActivityStatus @default(PENDING)
  completedAt DateTime?      @map("completed_at")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  user       AuthUser  @relation("ActivityUser", fields: [userId], references: [id], onDelete: Cascade)
  project    Project?  @relation(fields: [projectId], references: [id])
  assignedBy AuthUser? @relation("ActivityGiver", fields: [assignedById], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([assignedById])
  @@map("activities")
}

enum ActivityStatus {
  PENDING
  PENDING_STATUS
  IN_PROGRESS
  COMPLETED
  COMPLETED_LATE
  LATE_WITH_REASON
}

model LeaveRequest {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  managerId String @map("manager_id")
  financeId String @map("finance_id")

  startDate DateTime    @map("start_date")
  endDate   DateTime    @map("end_date")
  reason    String      @db.Text
  status    LeaveStatus @default(PENDING)
  managerStatus LeaveStatus @default(PENDING) @map("manager_status")
  financeStatus LeaveStatus @default(PENDING) @map("finance_status")

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user    AuthUser @relation("LeaveRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  manager AuthUser @relation("LeaveRequestManager", fields: [managerId], references: [id])
  finance AuthUser @relation("LeaveRequestFinance", fields: [financeId], references: [id])

  @@index([userId])
  @@index([managerId])
  @@index([financeId])
  @@map("leave_requests")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// --- INFORMASI APLIKASI ---
model ApplicationInfo {
  id                  String    @id @default(uuid())
  idInstansi          Int?      @map("id_instansi")
  namaInstansi        String?   @map("nama_instansi") @db.VarChar(255)
  namaProyek          String?   @map("nama_proyek") @db.VarChar(255)
  tahunProyek         Int?      @map("tahun_proyek")
  picClient           String?   @map("pic_client") @db.VarChar(255)
  picNo               String?   @map("pic_no") @db.VarChar(15)
  informasiTeknisDev  String?   @map("informasi_teknis_dev") @db.Text
  informasiTeknisProd String?   @map("informasi_teknis_prod") @db.Text
  createdAt           DateTime? @default(now()) @map("created_at")
  createdBy           String?   @map("created_by") @db.VarChar(200)
  updatedAt           DateTime? @updatedAt @map("updated_at")
  updatedBy           String?   @map("updated_by") @db.VarChar(200)

  files               ApplicationInfoFile[]
  teamMembers         ApplicationInfoTeam[]

  @@map("informasi_aplikasi")
}

model ApplicationInfoFile {
  id                  String   @id @default(uuid())
  idInformasiAplikasi String?  @map("id_informasi_aplikasi")
  namaFile            String?  @map("nama_file") @db.VarChar(255)
  pathFile            String?  @map("path_file") @db.VarChar(255)
  extension           String?  @map("extension") @db.VarChar(10)
  clientName          String?  @map("client_name") @db.VarChar(255)
  fileSize            Float?   @map("file_size")

  applicationInfo     ApplicationInfo? @relation(fields: [idInformasiAplikasi], references: [id], onDelete: Cascade)

  @@map("informasi_aplikasi_files")
}

model ApplicationInfoTeam {
  id                  String   @id @default(uuid())
  idInformasiAplikasi String?  @map("id_informasi_aplikasi")
  
  userId              String?  @map("user_id")
  user                AuthUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  idUserGroup         Int?     @map("id_user_group")
  namaTeam            String?  @map("nama_team") @db.VarChar(255)
  namaUsrGroup        String?  @map("nama_usr_group") @db.VarChar(255)

  applicationInfo     ApplicationInfo? @relation(fields: [idInformasiAplikasi], references: [id], onDelete: Cascade)

  @@map("informasi_aplikasi_team")
}

// MODEL KOPERASI
// Record anggota_ref / KTA hanya dibuat setelah AuthUser.statusRegistrasi = DISETUJUI
model kopdes_hub_sch_anggota_koperasi {
  anggota_ref        String             @id @default(uuid()) @unique(map: "kopdes_hub_sch_anggota_koperasi_unique")
  userId             String?            @unique @map("user_id")
  koperasi_ref       String
  nama               String?
  nik                String?
  alamat_lengkap     String?            @db.Text
  kode_wilayah       String?
  jenis_kelamin      String?
  status_keanggotaan String?            @default("AKTIF")
  nomor_kta          String?            @unique @map("nomor_kta") @db.VarChar(30)
  tanggal_terdaftar  DateTime?          @db.Date
  dibuat_pada        DateTime?          @db.Timestamp(6)
  diperbarui_pada    DateTime?          @db.Timestamp(6)
  file_ktp           String?
  file_selfie_ktp    String?            @map("file_selfie_ktp")
  status_akun        String?
  pekerjaan          String?

  authUser                                  AuthUser?                                 @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  kopdes_hub_sch_referensi_wilayah          kopdes_hub_sch_referensi_wilayah?         @relation(fields: [kode_wilayah], references: [kode_wilayah], onDelete: NoAction, onUpdate: NoAction, map: "fk_anggota_koperasi_kode_wilayah_96a41cef")
  kopdes_hub_sch_referensi_koperasi_wilayah kopdes_hub_sch_referensi_koperasi_wilayah @relation(fields: [koperasi_ref], references: [koperasi_ref], onDelete: NoAction, onUpdate: NoAction, map: "fk_anggota_koperasi_koperasi_ref_b8176ae0")
  kopdes_hub_sch_simpanan_anggota           kopdes_hub_sch_simpanan_anggota[]
}

model kopdes_hub_sch_karyawan_koperasi {
  karyawan_ref                              String                                    @id(map: "kopdes_hub_sch_karyawan_koperasi_pk")
  koperasi_ref                              String
  nama                                      String?
  jabatan                                   String?
  nomor_hp_karyawan                         String?
  jenis_kelamin                             String?
  nik                                       String?
  email                                     String?
  status_karyawan                           String?
  dibuat_pada                               DateTime?                                 @db.Timestamp(6)
  diperbarui_pada                           DateTime?                                 @db.Timestamp(6)
  kopdes_hub_sch_referensi_koperasi_wilayah kopdes_hub_sch_referensi_koperasi_wilayah @relation(fields: [koperasi_ref], references: [koperasi_ref], onDelete: NoAction, onUpdate: NoAction, map: "fk_karyawan_koperasi_koperasi_ref_4e47588f")
}

model kopdes_hub_sch_pengurus_koperasi {
  pengurus_ref                              String                                    @id(map: "kopdes_hub_sch_pengurus_koperasi_pk")
  koperasi_ref                              String
  nama                                      String?
  jabatan                                   String?
  status                                    String?
  no_hp                                     String?
  nik                                       String?
  jenis_kelamin                             String?
  foto_profil                               String?
  email                                     String?
  alamat                                    String?
  kode_pos                                  String?
  tanggal_lahir                             String?
  status_pendidikan                         String?
  periode_mulai                             String?
  periode_selesai                           DateTime?                                 @db.Date
  file_ktp                                  String?
  sumber_data                               String?
  dibuat_pada                               DateTime?                                 @db.Timestamp(6)
  diperbarui_pada                           DateTime?                                 @db.Timestamp(6)
  kopdes_hub_sch_referensi_koperasi_wilayah kopdes_hub_sch_referensi_koperasi_wilayah @relation(fields: [koperasi_ref], references: [koperasi_ref], onDelete: NoAction, onUpdate: NoAction, map: "fk_pengurus_koperasi_koperasi_ref_762eb9ec")
}

model kopdes_hub_sch_rat_koperasi {
  rat_sample_id                             String                                    @id(map: "kopdes_hub_sch_rat_koperasi_pk")
  koperasi_ref                              String
  jenis_sektor_koperasi                     String?
  urutan_rat                                String?
  tahun_buku                                Int?                                      @db.SmallInt
  tahun_rencana_kerja                       Int?                                      @db.SmallInt
  tahun_rencana_anggaran                    Int?                                      @db.SmallInt
  tanggal_rat                               DateTime?                                 @db.Date
