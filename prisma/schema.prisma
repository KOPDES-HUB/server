model kopdes_hub_sch_referensi_wilayah {
  provinsi                        String?
  kab_kota                        String?
  kecamatan                       String?
  desa_kelurahan                  String?
  kode_wilayah                    String                            @id
  dibuat_pada                     DateTime?                         @db.Timestamp(6)
  diperbarui_pada                 DateTime?                         @db.Timestamp(6)
  kopdes_hub_sch_anggota_koperasi kopdes_hub_sch_anggota_koperasi[]
}

model kopdes_hub_sch_simpanan_anggota {
  simpanan_ref                              String                                    @unique(map: "kopdes_hub_sch_simpanan_anggota_unique")
  koperasi_ref                              String
  anggota_ref                               String
  periode_pembayaran                        String?
  jumlah_simpanan                           Decimal?                                  @db.Decimal
  status                                    String?
  dibuat_pada                               DateTime?                                 @db.Timestamp(6)
  dibayar_pada                              DateTime?                                 @db.Timestamp(6)
  kopdes_hub_sch_anggota_koperasi           kopdes_hub_sch_anggota_koperasi           @relation(fields: [anggota_ref], references: [anggota_ref], map: "fk_simpanan_anggota_anggota_koperasi")
  kopdes_hub_sch_referensi_koperasi_wilayah kopdes_hub_sch_referensi_koperasi_wilayah @relation(fields: [koperasi_ref], references: [koperasi_ref], onDelete: NoAction, onUpdate: NoAction, map: "fk_simpanan_anggota_koperasi_ref_c7fd2f70")
}

model kopdes_hub_sch_profil_koperasi {
  koperasi_ref          String    @unique(map: "kopdes_hub_sch_profil_koperasi_pk")
  nama_koperasi         String?   @db.Text
  status_registrasi     String?   @db.Text
  bentuk_koperasi       String?   @db.Text
  kategori_usaha        String?   @db.Text
  nik_koperasi          String?   @db.Text
  alamat_lengkap        String?   @db.Text
  kode_pos              String?   @db.Text
  koordinat_dibulatkan  String?   @db.Text
  modal_awal            String?   @db.Text
  sumber_persetujuan    String?   @db.Text
  tentang_koperasi      String?   @db.Text
  pola_pengelolaan      String?   @db.Text
  metode_pengisian      String?   @db.Text
  dibuat_pada           DateTime? @db.Timestamp(6)
  diperbarui_pada       DateTime? @db.Timestamp(6)
}